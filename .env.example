# lark-fashion-cockpit 环境变量配置（拷贝成 .env 后填值）

# ============== 飞书 base / 应用 ==============
# 你的 lark-fashion-cockpit 主多维表 base token
# 跑 `lark-cli base +base-create --name lark-fashion-cockpit` 自动建一份
LARK_FASHION_COCKPIT_BASE_TOKEN=

# 老板独人通知群（接收所有汇报卡片）
LARK_FASHION_COCKPIT_BOSS_CHAT=oc_xxxxxxxxxxxxxxxxxx

# 老板 open_id（事件监听只响应他）
LARK_FASHION_COCKPIT_BOSS_OPEN_ID=ou_xxxxxxxxxxxxxxxxxx

# ============== AI 模型凭证 ==============
# 豆包多模态（视觉 + ASR）— 火山方舟 https://console.volcengine.com/ark
DOUBAO_API_KEY=ark-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
DOUBAO_MODEL=doubao-1-5-vision-pro-32k-250115

# DeepSeek（创作 + 分析）— https://platform.deepseek.com
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
DEEPSEEK_MODEL=deepseek-v4-pro
DEEPSEEK_MODEL_FAST=deepseek-v4-flash
DEEPSEEK_BASE_URL=https://api.deepseek.com

# ============== 第三方平台 ==============
# 抖音 web 版 cookie（用于 douyin-monitor 爬视频数据）
# 获取：登录抖音网页版 → F12 → Network → 任意请求 → 复制 Cookie 头
DOUYIN_COOKIE=

# 可灵 AI 文生视频（可选，用于 video-generator skill）
KLING_ACCESS_KEY=
KLING_SECRET_KEY=

# 飞书 Aily 应用 ID（搭好 Aily 应用后填）
AILY_APP_ID=

# ============== 多维表 table id 速查（init-cockpit 自动建表后填）==============
TABLE_PRODUCT_LIBRARY=tblxxxxxxxxxx     # 01_产品库
TABLE_SALES_4PLATFORMS=tblxxxxxxxxxx    # 02_4平台销售
TABLE_STOCK_ALERT=tblxxxxxxxxxx         # 03_库存预警
TABLE_LAUNCH_WAVES=tblxxxxxxxxxx        # 04_上新波段
TABLE_TASKS=tblxxxxxxxxxx               # 05_任务清单
TABLE_LIVESTREAM_RECORDS=tblxxxxxxxxxx  # 24_直播记录
TABLE_TODOS=tblxxxxxxxxxx               # 25_未完成事项
TABLE_BOSS_QA=tblxxxxxxxxxx             # 26_老板语料库
TABLE_BLOGGER_VIDEOS=tblxxxxxxxxxx      # 27_对标博主视频监控
